# ================================================================
# CONFIGURATION ELOQUENCE - DÉVELOPPEMENT LOCAL
# ================================================================
# Variables d'environnement pour déploiement local
# ================================================================

# === ENVIRONNEMENT ===
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
NODE_ENV=development

# === DOMAINE ET URLS ===
DOMAIN=localhost
BASE_URL=http://localhost:8080
API_URL=http://localhost:8080/api
FRONTEND_URL=http://localhost:3000

# === SÉCURITÉ ===
JWT_SECRET=dev_jwt_secret_change_in_production_123456789
ENCRYPTION_KEY=dev_encryption_key_change_in_production_123456789

# === REDIS ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_TIMEOUT=5

# === API CONFIGURATION ===
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=2
API_TIMEOUT=60
MAX_UPLOAD_SIZE=52428800
RATE_LIMIT_PER_MINUTE=1000

# === VOSK STT ===
VOSK_HOST=vosk-stt
VOSK_PORT=8002
VOSK_SERVICE_URL=http://vosk-stt:8002
VOSK_MODEL_PATH=/app/models/vosk-model-fr
VOSK_TIMEOUT=30

# === MISTRAL IA ===
MISTRAL_HOST=mistral
MISTRAL_PORT=8001
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest
MISTRAL_TIMEOUT=180
MISTRAL_MAX_TOKENS=4096
SCALEWAY_MISTRAL_URL=https://api.scaleway.ai/your-project-id/v1

# === LIVEKIT ===
LIVEKIT_HOST=livekit
LIVEKIT_PORT=7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret123456789abcdef0123456789abcdef
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_ROOM_TIMEOUT=3600

# === CORS ET SÉCURITÉ WEB ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400
SECURE_COOKIES=false
CSRF_PROTECTION=false
SESSION_TIMEOUT=3600

# === MONITORING ===
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30
LOG_RETENTION_DAYS=7
MONITORING_PORT=9090

# === PERFORMANCE ===
WORKER_PROCESSES=2
WORKER_CONNECTIONS=1024
KEEPALIVE_TIMEOUT=65
CLIENT_MAX_BODY_SIZE=50M
PROXY_TIMEOUT=60

# === CACHE ===
CACHE_TTL=300
CACHE_MAX_SIZE=50MB
STATIC_CACHE_TTL=3600

# === EXTERNAL APIS ===
# Remplacez par vos vraies clés API pour les tests
OPENAI_API_KEY=your_openai_api_key_here

# === RATE LIMITING ===
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_SKIP_SUCCESSFUL=true

# === LOGGING ===
LOG_FORMAT=pretty
LOG_TIMESTAMP=true
LOG_CORRELATION_ID=true
ACCESS_LOG_ENABLED=true
ERROR_LOG_ENABLED=true

# === MEDIA PROCESSING ===
AUDIO_MAX_DURATION=300
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_FORMAT=wav

# === FEATURE FLAGS ===
FEATURE_VOICE_ANALYSIS=true
FEATURE_AI_CONVERSATION=true
FEATURE_REAL_TIME_STT=true
FEATURE_GAMIFICATION=true
FEATURE_ANALYTICS=true

# === DEVELOPMENT ===
DEV_SKIP_AUTH=false
DEV_MOCK_APIS=false
DEV_VERBOSE_LOGGING=true

# === MAINTENANCE ===
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="Service temporairement indisponible"

# ================================================================
# INSTRUCTIONS POUR LE DÉVELOPPEMENT
# ================================================================
# 
# 1. Ce fichier est configuré pour le développement local
# 2. Remplacez les clés API par vos vraies clés pour tester
# 3. Les services sont configurés pour communiquer via Docker
# 4. Les logs sont en mode verbose pour le debugging
# 
# POUR LA PRODUCTION:
# - Utilisez .env.production comme base
# - Configurez un domaine réel
# - Activez HTTPS et la sécurité
# - Utilisez des secrets Docker
# 
# ================================================================
